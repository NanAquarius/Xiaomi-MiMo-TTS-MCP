# =============================================================================
# Xiaomi MiMo TTS MCP — environment variables
# =============================================================================

# --- API credentials (required) ----------------------------------------------
# Pay-as-you-go key looks like sk-xxxxx (from "API Keys" page).
# Token Plan key looks like   tp-xxxxx (from "Subscription / Plan Manage" page).
# The two keys are NOT interchangeable.
MIMO_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Plan & region (optional) ------------------------------------------------
# Auto-detected from the key prefix when omitted:
#   sk-... → pay-as-you-go      base: https://api.xiaomimimo.com/v1
#   tp-... → token-plan (cn)    base: https://token-plan-cn.xiaomimimo.com/v1
#
# Override explicitly if you want a different cluster:
# MIMO_PLAN=token-plan       # pay-as-you-go | token-plan
# MIMO_REGION=cn             # cn | sgp | ams (Token Plan only)
#
# Or hard-set the full URL (wins over MIMO_PLAN / MIMO_REGION):
# MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# --- Output & transport ------------------------------------------------------
# MIMO_OUTPUT_DIR=./tts_output
# MCP_TRANSPORT=stdio        # stdio | sse | streamable-http
# MCP_HOST=0.0.0.0
# MCP_PORT=8000

# --- Auth for remote/HTTP deployment (STRONGLY recommended) ------------------
# When set, HTTP requests must carry: Authorization: Bearer <MCP_AUTH_TOKEN>
# Generate one with:  openssl rand -hex 32
# MCP_AUTH_TOKEN=replace-me-with-a-long-random-string
